# Database
DATABASE_URL=postgresql://roofing:roofing@localhost:5432/roofing_scheduler

# JobNimbus API (READ-ONLY)
JOBNIMBUS_API_KEY=your_jobnimbus_api_key_here
JOBNIMBUS_BASE_URL=https://app.jobnimbus.com/api1

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# BamWx API (Phase 3 - leave blank for now)
BAMWX_API_KEY=
BAMWX_BASE_URL=

# --- Clerk auth ---
# Clerk Dashboard → API Keys
# CLERK_JWKS_URL is the "JWKS endpoint" — looks like:
#   https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_JWT_ISSUER is the "Frontend API" / issuer URL — looks like:
#   https://<your-instance>.clerk.accounts.dev
#
# Also configure a JWT Template in Clerk that injects these custom claims
# from public_metadata so the backend can read approval state:
#   {
#     "email":    "{{user.primary_email_address}}",
#     "name":     "{{user.full_name}}",
#     "approved": "{{user.public_metadata.approved}}",
#     "admin":    "{{user.public_metadata.admin}}"
#   }
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
